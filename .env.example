# Copy to .env.local and fill in values from Supabase dashboard.

# Supabase — Dashboard -> Project Settings -> API
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_KEY="<service_role key — NOT anon>"

# NextAuth — any random string (`openssl rand -base64 32`)
NEXTAUTH_SECRET=""

# NextAuth — required in production (Vercel etc). Unused in local dev.
# NEXTAUTH_URL="https://your-domain.com"

# Admin seed credentials — only used on first login when User table is empty.
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD="crossfit123"
